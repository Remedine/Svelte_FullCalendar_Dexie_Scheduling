# ============================================
# Capital City Windows - Environment Variables
# Copy this file to .env.local (or .env) and fill in values.
# NEVER commit real secrets.
# ============================================

# PocketBase backend URL (required for auth + sync)
# Local dev: http://127.0.0.1:8090
# Production / self-hosted: Point to the PocketBase instance running on (or reachable from) the same server.
# Example for same-machine setup: http://127.0.0.1:8090  or  http://localhost:8090
# If using a reverse proxy / domain: https://pb.yourdomain.com
PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Optional: Add other public config here if needed in the future.
# All client-exposed vars must be prefixed with PUBLIC_
